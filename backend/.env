# S6S IoT Platform - Backend Environment Configuration
# Database Configuration - UPDATE THESE VALUES
DB_HOST=localhost
DB_PORT=5432
DB_NAME=s6s_iot
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_SIZE=20
DB_SSL=false

# JWT Configuration
JWT_SECRET=s6s-iot-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=s6s-iot-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# MQTT Broker Configuration
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_USERNAME=s6s_iot
MQTT_PASSWORD=mqtt_password
MQTT_WEBSOCKET_PORT=8083
MQTT_QOS=1

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
